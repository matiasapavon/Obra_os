# Obra OS — variables de entorno
# Copiá este archivo a .env.local y completá con los datos de tu proyecto Supabase.
# .env.local NO se sube a git (tiene secretos). Estas mismas variables van también
# cargadas en Vercel (Project Settings > Environment Variables).

# Supabase > Project Settings > API Keys (usar la PUBLISHABLE, no la secret)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
